<?xml version="1.0" encoding="utf-8"?>
<Patch>

	<Operation Class="PatchOperationSequence">
		<operations>
			<!--heavy power skeleton-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_HeavyPowerSkeleton"]/statBases/ArmorRating_Sharp</xpath>
				<value>
					<ArmorRating_Sharp>15</ArmorRating_Sharp>
				</value>
			</li>
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_HeavyPowerSkeleton"]/statBases/ArmorRating_Blunt</xpath>
				<value>
					<ArmorRating_Blunt>45</ArmorRating_Blunt>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_HeavyPowerSkeleton"]/statBases</xpath>
				<value>
					<Bulk>25</Bulk>
					<WornBulk>8</WornBulk>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_HeavyPowerSkeleton"]/equippedStatOffsets</xpath>
				<value>
					<CarryWeight>150</CarryWeight>
					<CarryBulk>150</CarryBulk>
				</value>
			</li>

			<!--DMSE_Apparel_RangerHelmet-->
			<li Class="PatchOperationReplace">
				<xpath>
					Defs/ThingDef[defName="DMSE_Apparel_RangerHelmet"]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>5</StuffEffectMultiplierArmor>
					<Bulk>5</Bulk>
					<WornBulk>2</WornBulk>
				</value>
			</li>
			
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_RangerHelmet"]/apparel/layers</xpath>
				<value>
					<li>StrappedHead</li>
				</value>
			</li>
			
			<li Class="PatchOperationAddModExtension">
				<xpath>Defs/ThingDef[defName="DMSE_Apparel_RangerHelmet"]</xpath>
				<value>
					<li Class="CombatExtended.ApparelDefExtension">
						<isRadioPack>true</isRadioPack>
					</li>
				</value>
			</li>
			
			<!--DMS_Apparel_Uniform-->
			<li Class="PatchOperationReplace">
				<xpath>Defs/ThingDef[defName="DMS_Apparel_Uniform"]/statBases/StuffEffectMultiplierArmor</xpath>
				<value>
					<StuffEffectMultiplierArmor>4</StuffEffectMultiplierArmor>
				</value>
			</li>

			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMS_Apparel_Uniform"]/statBases</xpath>
				<value>
					<Bulk>4</Bulk>
					<WornBulk>0</WornBulk>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMS_Apparel_Uniform"]</xpath>
				<value>
					<equippedStatOffsets>
						<CarryBulk>20</CarryBulk>
					</equippedStatOffsets>
				</value>
			</li>
			<li Class="PatchOperationAdd">
				<xpath>Defs/ThingDef[defName="DMS_Apparel_Uniform"]/apparel/bodyPartGroups</xpath>
				<value>
					<li>Hands</li>
					<li>Feet</li>
				</value>
			</li>

			<li Class="PatchOperationAddModExtension">
				<xpath>Defs/ThingDef[defName="DMS_Apparel_Uniform"]</xpath>
				<value>
					<li Class="CombatExtended.PartialArmorExt">
						<stats>
							<li>
								<ArmorRating_Sharp>0.75</ArmorRating_Sharp>
								<parts>
									<li>Hand</li>
								</parts>
							</li>
							<li>
								<ArmorRating_Blunt>0.75</ArmorRating_Blunt>
								<parts>
									<li>Hand</li>
								</parts>
							</li>
						</stats>
					</li>
				</value>
			</li>
		</operations>
	</Operation>
	
</Patch>
