<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="DMSE_BaseBuilding" Name="DMSE_BaseLootBox" Abstract="True">
        <category>Building</category>
        <thingClass>Fortified.Building_SurplusContainer</thingClass>
        <rotatable>true</rotatable>
        <useHitPoints>true</useHitPoints>
        <destroyable>true</destroyable>
        
        <designationCategory inherit="false"/>
        <statBases>
            <MaxHitPoints>500</MaxHitPoints>
        </statBases>
        <building>
            <expandHomeArea>false</expandHomeArea>
            <claimable>true</claimable>
            <deconstructible>false</deconstructible>
        </building>
        <pathCost>90</pathCost>
    </ThingDef>

    <!-- Cargo container -->
    <ThingDef ParentName="DMSE_BaseLootBox">
        <defName>DMSE_Cargo</defName>
        <label>cargo container</label>
        <!-- Commonly known as the "standard transport container," this is an interstellar-standard cargo box used between Colonial Fleet motherships and orbital bases. It can flexibly carry equipment and resources in many standard sizes.\n\nThese large containers require dedicated loading equipment and heavy machinery, so they are mostly used on transfer platforms and large bases with complete loading systems. Because of their transport-friendly format, people on rim worlds also repurpose them into platforms and temporary shelters. -->
        <description>Commonly known as "standard transport containers," these are standard interstellar cargo boxes used for transporting equipment and resources between colony fleet motherships and various orbital bases. They can flexibly accommodate equipment and resources of various standard sizes.\n\nThese large containers require specialized loading equipment and heavy machinery for transport, and are therefore primarily used as transshipment platforms and in large bases equipped with sophisticated loading and unloading systems. Due to their convenient transport specifications, people in the Edge World also prefer to convert them into platforms and temporary dwellings for various purposes.</description>
        <rotatable>true</rotatable>
        <tickerType>Normal</tickerType>
        <building>
            <paintable>true</paintable>
        </building>
        <graphicData>
            <color>(0.5,0.5,0.5)</color>
            <texPath>Things/Building/Lootable/cargo</texPath>
            <drawSize>(4.3,6.45)</drawSize>
            <drawOffset>(0,0.03,0)</drawOffset>
            <graphicClass>Graphic_Random</graphicClass>
            <shaderType>CutoutComplex</shaderType>
            <onGroundRandomRotateAngle>5</onGroundRandomRotateAngle>
        </graphicData>
        <fillPercent>1</fillPercent>
        <killedLeavingsRanges>
            <ChunkSlagSteel>2~4</ChunkSlagSteel>
        </killedLeavingsRanges>
        <staticSunShadowHeight>0.7</staticSunShadowHeight>
        <size>(2,4)</size>
        <defaultPlacingRot>0</defaultPlacingRot>
        <comps>
            <li Class="Fortified.CompProperties_RandomColorOnSpawn">
                <colorDefs>
                    <li>Structure_GreenFaded</li>
                    <li>Structure_OrangePastel</li>
                    <li>Structure_Red</li>
                    <li>Structure_White</li>
                </colorDefs>
            </li>
        </comps>
        <modExtensions>
            <li Class="Fortified.ModExtension_Lootbox">
                <sound>CrateOpeningStarted</sound>
                <openedGraphicdata>
                    <texPath>Things/Building/Lootable/cargoOpen</texPath>
                    <drawSize>(4.3,6.45)</drawSize>
                    <drawOffset>(0,0.03,0)</drawOffset>
                    <graphicClass>Graphic_Random</graphicClass>
                    <shaderType>CutoutComplex</shaderType>
                    <onGroundRandomRotateAngle>5</onGroundRandomRotateAngle>
                </openedGraphicdata>
                <countRange>3~6</countRange>
                <loots>
                    <li>Reward_ItemsStandard</li>
                    <li MayRequire="Aoba.DeadManSwitch.AncientCorps">DMSAC_CargoLoots</li>
                    <li MayRequire="Aoba.DeadManSwitch.AncientCorps">DMSAC_RTC_CompLoots</li>
                </loots>
            </li>
        </modExtensions>
    </ThingDef>

    <!-- Fuel silo -->
    <ThingDef ParentName="DMSE_BaseLootBox">
        <defName>DMSE_FuelSilo</defName>
        <label>fuel silo</label>
        <!-- A large tank for storing liquid fuels, using multiple metal layers and special alloys to keep various fuels safe inside a massive body. It is common on orbital platforms and large fuel transport ships.\n\nThis particular tank is still intact and may contain a small amount of residual fuel, but extraction takes significant time without pump equipment. -->
        <description>A large storage tank for liquid fuels, using multiple layers of metal plates and special alloys to safely store various fuels within its massive body, is commonly found on orbital platforms and large fuel transport ships.\n\nThis tank is well-preserved and may still contain a small amount of residual fuel, but extracting it without pumping equipment would take considerable time.</description>
        <rotatable>false</rotatable>
        <tickerType>Normal</tickerType>
        <building>
            <deconstructible>false</deconstructible>
            <paintable>true</paintable>
        </building>
        <graphicData>
            <texPath>Things/Building/Lootable/fuelSilo/buildingA</texPath>
            <drawSize>(4,4)</drawSize>
            <drawOffset>(0,0.001,0.35)</drawOffset>
            <graphicClass>Graphic_Single</graphicClass>
            <shaderType>CutoutComplex</shaderType>
        </graphicData>
        <fillPercent>1</fillPercent>
        <killedLeavingsRanges>
            <ChunkSlagSteel>2~4</ChunkSlagSteel>
        </killedLeavingsRanges>
        <costList>
            <Steel>150</Steel>
        </costList>
        <staticSunShadowHeight>0.25</staticSunShadowHeight>
        <size>(3,3)</size>
        <defaultPlacingRot>0</defaultPlacingRot>
        <comps>
            <li Class="Fortified.CompProperties_RandomColorOnSpawn">
                <colorChance>0.34</colorChance>
                <colorDefs>
                    <li>Structure_White</li>
                </colorDefs>
            </li>
        </comps>
        <modExtensions>
            <li Class="Fortified.ModExtension_Lootbox">
                <sound>CrateOpeningStarted</sound>
                <openedGraphicdata>
                    <texPath>Things/Building/Lootable/fuelSilo/buildingA_Open</texPath>
                    <drawSize>(4,4)</drawSize>
                    <drawOffset>(0,0.001,0.35)</drawOffset>
                    <graphicClass>Graphic_Single</graphicClass>
                    <shaderType>CutoutComplex</shaderType>
                </openedGraphicdata>
                <loots>
                    <li>DMSE_FuelSiloLoots</li>
                </loots>
            </li>
        </modExtensions>
    </ThingDef>

    <ThingSetMakerDef>
        <defName>DMSE_FuelSiloLoots</defName>
        <root Class="ThingSetMaker_RandomOption">
            <options>
                <li>
                    <weight>8</weight>
                    <thingSetMaker Class="ThingSetMaker_StackCount">
                        <fixedParams>
                            <filter>
                                <thingDefs>
                                    <li>Chemfuel</li>
                                </thingDefs>
                            </filter>
                            <countRange>25~750</countRange>
                        </fixedParams>
                    </thingSetMaker>
                </li>
            </options>
        </root>
    </ThingSetMakerDef>

    <ThingDef ParentName="DMSE_BaseLootBox">
        <defName>DMSE_Crate</defName>
        <label>rabbit crate</label>
        <!-- Nicknamed "Rabbit," this one-eighth-size standard transport container is widely used for building and resupplying small outposts. It fits in small-to-medium shuttle bays and light trucks, and can be loaded or unloaded on-site by personnel using powered support units.\n\nColonial Fleet cargo ships often carry tens of thousands of standard containers, then repackage them on orbital transfer platforms into this container type for ground facilities and factories. -->
        <description>Nicknamed "Rabbit," these one-eighths standard transport containers are widely used for the construction and resupply of small outposts. They fit perfectly into the cargo holds of small to medium-sized shuttles and light trucks, and are loaded and unloaded directly on-site by humans wearing power units.\n\nCargo ships from colonial fleets typically carry tens of thousands of standard transport containers, which will distributed to ground facilities and factories via transfer platforms in space orbit.</description>
        <rotatable>true</rotatable>
        <tickerType>Normal</tickerType>
        <building>
            <deconstructible>true</deconstructible>
            <paintable>true</paintable>
        </building>
        <graphicData>
            <texPath>Things/Building/Lootable/crate</texPath>
            <drawSize>(3,2)</drawSize>
            <drawOffset>(0,0.01,0)</drawOffset>
            <graphicClass>Graphic_Random</graphicClass>
            <shaderType>Cutout</shaderType>
        </graphicData>
        <fillPercent>0.4</fillPercent>
        <costList>
            <WoodLog>20</WoodLog>
        </costList>
        <staticSunShadowHeight>0.2</staticSunShadowHeight>
        <size>(2,1)</size>
        <defaultPlacingRot>2</defaultPlacingRot>
        <comps>
            <li Class="Fortified.CompProperties_RandomColorOnSpawn">
                <colorChance>0.34</colorChance>
                <colorDefs>
                    <li>Structure_White</li>
                    <li>Structure_GrayLight</li>
                    <li>Structure_Cream</li>
                    <li>Structure_Limestone</li>
                </colorDefs>
            </li>
        </comps>
        <modExtensions>
            <li Class="Fortified.ModExtension_Lootbox">
                <sound>CrateOpeningStarted</sound>
                <openedGraphicdata>
                    <texPath>Things/Building/Lootable/crateOpen</texPath>
                    <drawSize>(3,2)</drawSize>
                    <drawOffset>(0,0.01,0)</drawOffset>
                    <graphicClass>Graphic_Random</graphicClass>
                    <shaderType>Cutout</shaderType>
                    <onGroundRandomRotateAngle>5</onGroundRandomRotateAngle>
                </openedGraphicdata>
                <loots>
                    <li>Reward_ItemsStandard</li>
                </loots>
            </li>
        </modExtensions>
    </ThingDef>

    <ThingDef ParentName="DMSE_BaseLootBox">
        <defName>DMSE_PackCrate</defName>
        <label>military parcel</label>
        <!-- A standard transport parcel for military supplies. Both the package and its contents appear to be recently manufactured and distributed alongside mechanized unit deployments. -->
        <description>A Standard issue parcel containing supplies for military logistics. These parcel seemed to have been produced recently and sent to various locations.</description>
        <rotatable>false</rotatable>
        <tickerType>Normal</tickerType>
        <building>
            <deconstructible>true</deconstructible>
            <paintable>true</paintable>
        </building>
        <graphicData>
            <texPath>Things/Building/Lootable/packCrate</texPath>
            <drawSize>(3,3)</drawSize>
            <drawOffset>(0,0.01,0)</drawOffset>
            <graphicClass>Graphic_Random</graphicClass>
            <shaderType>CutoutComplex</shaderType>
            <shadowData>
                <offset>(0,0,0)</offset>
                <volume>(2,0.8,2)</volume>
            </shadowData>
        </graphicData>
        <fillPercent>0.5</fillPercent>
        <costList>
            <Cloth>40</Cloth>
        </costList>
        <size>(2,2)</size>
        <defaultPlacingRot>0</defaultPlacingRot>
        <comps>
            <li Class="Fortified.CompProperties_RandomColorOnSpawn">
                <colorChance>1</colorChance>
                <colorDefs>
                    <li>Structure_GreenFaded</li>
                    <li>Structure_OrangePastel</li>
                    <li>Structure_Red</li>
                    <li>Structure_White</li>
                </colorDefs>
            </li>
        </comps>
        <modExtensions>
            <li Class="Fortified.ModExtension_Lootbox">
                <sound>CrateOpeningStarted</sound>
                <openedGraphicdata>
                    <texPath>Things/Building/Lootable/packCrateOpen</texPath>
                    <drawSize>(3,3)</drawSize>
                    <graphicClass>Graphic_Random</graphicClass>
                    <shaderType>CutoutComplex</shaderType>
                    <onGroundRandomRotateAngle>5</onGroundRandomRotateAngle>
                    <shadowData>
                        <offset>(0,0,0)</offset>
                        <volume>(2,0.25,2)</volume>
                    </shadowData>
                </openedGraphicdata>
                <loots>
                    <li>Reward_ItemsStandard</li>
                    <li MayRequire="Aoba.DeadManSwitch.AncientCorps">DMSAC_PackLoots</li>
                </loots>
            </li>
        </modExtensions>
    </ThingDef>
</Defs>