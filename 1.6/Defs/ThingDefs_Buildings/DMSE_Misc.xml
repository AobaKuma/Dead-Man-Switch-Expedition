          <!-- Anomaly -->
          <li MayRequire="Ludeon.RimWorld.Anomaly">WarpedObelisk_Duplicator</li>    <!-- WarpedObelisk_Duplicator -->
          <li MayRequire="Ludeon.RimWorld.Anomaly">WarpedObelisk_Abductor</li>    <!-- WarpedObelisk_Abductor -->
          <li MayRequire="Ludeon.RimWorld.Anomaly">WarpedObelisk_Mutator</li>    <!-- WarpedObelisk_Mutator -->
          <!--fxz.ratkinanomaly.update-->
          <li MayRequire="fxz.ratkinanomaly.update">RA_PokerSoldierArrival</li>    <!-- RA_PokerSoldierArrival -->
          <li MayRequire="fxz.ratkinanomaly.update">RA_DarkKnightArrivalPre</li>    <!-- RA_DarkKnightArrivalPre -->
          <li MayRequire="fxz.ratkinanomaly.update">RA_DarkKnightArrivalPre_Commander</li>    <!-- RA_DarkKnightArrivalPre_Commander -->
          <li MayRequire="fxz.ratkinanomaly.update">RA_DarkKnightArrival</li>    <!-- RA_DarkKnightArrival -->
