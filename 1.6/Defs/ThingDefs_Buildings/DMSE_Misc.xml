        </incidentsWhitelist>
        <coolDownPerRaidPoint>24</coolDownPerRaidPoint>
        <powerCostPerColonist>1000</powerCostPerColonist>
        <activeEffecter>DMSE_Device_Active</activeEffecter>
        <triggerEffecter>DMSE_Device_Trigger</triggerEffecter>
