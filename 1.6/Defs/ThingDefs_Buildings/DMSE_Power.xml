<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>DMSE_Battery</defName>
    <label>graphene battery</label>
    <!-- 一種應用石墨烯材料的電池。相比於常見的電池能夠有更高的容量與充電效率，然而其高能級的代價是在常溫下有著比傳統電池更高的自放電功率。 -->
    <description>A battery that utilizes graphene materials, store electricity for later use. Compared to common batteries, it has higher capacity and charging efficiency; however, its high energy level comes at the cost of a higher self-discharge power than traditional batteries. Won't explode when exposed to rain or fire.</description>
    <drawerType>MapMeshAndRealTime</drawerType>
    <thingClass>Building_Battery</thingClass>
    <graphicData>
      <texPath>Things/Building/DMSE_Battery</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2,4)</drawSize>
      <damageData>
        <cornerTL>Damage/Corner</cornerTL>
        <cornerTR>Damage/Corner</cornerTR>
        <cornerBL>Damage/Corner</cornerBL>
        <cornerBR>Damage/Corner</cornerBR>
      </damageData>
    </graphicData>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <blockWind>true</blockWind>
    <castEdgeShadows>true</castEdgeShadows>
    <fillPercent>0.40</fillPercent>
    <tickerType>Normal</tickerType>
    <minifiedDef>MinifiedThing</minifiedDef>
    <thingCategories>
      <li>BuildingsPower</li>
    </thingCategories>
    <statBases>
      <MaxHitPoints>400</MaxHitPoints>
      <WorkToBuild>3000</WorkToBuild>
      <Mass>35</Mass>
      <Flammability>0</Flammability>
      <Beauty>0</Beauty>
    </statBases>
    <size>(1,3)</size>
    <building>
      <destroySound>BuildingDestroyed_Metal_Medium</destroySound>
    </building>
    <costList>
      <Tungsteel>120</Tungsteel>
      <DMSE_Graphene>50</DMSE_Graphene>
      <DMSE_TantastenAlloy>25</DMSE_TantastenAlloy>
      <ComponentStamped>5</ComponentStamped>
    </costList>
    <comps>
      <li Class="DMSE.CompProperties_BatteryTempSelfDischarge">
        <storedEnergyMax>4800</storedEnergyMax>
        <efficiency>0.95</efficiency>
        <shortCircuitInRain>false</shortCircuitInRain>
        <transmitsPower>true</transmitsPower>
        <zeroDischargeTemperature>20</zeroDischargeTemperature>
        <peakDistance>40</peakDistance>
        <maxSelfDischargeWatts>100</maxSelfDischargeWatts>
      </li>
      <li Class="CompProperties_Breakdownable" />
      <li Class="CompProperties_Stunnable">
        <useLargeEMPEffecter>true</useLargeEMPEffecter>
        <affectedDamageDefs>
          <li>EMP</li>
        </affectedDamageDefs>
      </li>
    </comps>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <designationCategory>Power</designationCategory>
    <uiOrder>2020</uiOrder>
    <staticSunShadowHeight>0.2</staticSunShadowHeight>
    <constructEffect>ConstructMetal</constructEffect>
    <canOverlapZones>false</canOverlapZones>
    <researchPrerequisites>
      <li>DMSE_OrbitalDynamics</li>
      <li>Batteries</li>
    </researchPrerequisites>
  </ThingDef>

  <!-- Photovoltaic panel -->
  <ThingDef ParentName="BuildingBase">
    <defName>DMSE_PhotovoltaicPanel</defName>
    <label>photovoltaic panel</label>
    <description>A solar panel that generates energy using the photovoltaic principle. It filters light through a graphene coating and uses the green light band to convert it into stable, usable electricity. However, because green light is easily scattered in the atmosphere, this type of solar panel can only be used in a vacuum. Nevertheless, due to atmospheric refraction, it can generate electricity at a lower power even at night.</description>
    <thingClass>Building</thingClass>
    <drawerType>MapMeshAndRealTime</drawerType>
    <graphicData>
      <texPath>Things/Building/DMSE_PhotovoltaicPanel</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(4,4)</drawSize>
      <shadowData>
        <volume>(3.5,0.75,3.4)</volume>
        <offset>(0,0,0)</offset>
      </shadowData>
      <damageData>
        <rect>(0,0.6,4,2.8)</rect>
      </damageData>
    </graphicData>
    <castEdgeShadows>true</castEdgeShadows>
    <rotatable>false</rotatable>
    <altitudeLayer>Building</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <pathCost>50</pathCost>
    <fillPercent>0.5</fillPercent>
    <canOverlapZones>false</canOverlapZones>
    <statBases>
      <MaxHitPoints>300</MaxHitPoints>
      <WorkToBuild>3000</WorkToBuild>
      <Flammability>0.7</Flammability>
    </statBases>
    <tickerType>Normal</tickerType>
    <size>(3,3)</size>
    <building>
      <destroySound>BuildingDestroyed_Metal_Big</destroySound>
    </building>
    <costList>
      <Tungsteel>100</Tungsteel>
      <DMSE_Graphene>75</DMSE_Graphene>
      <ComponentStamped>1</ComponentStamped>
    </costList>
    <comps>
      <li Class="CompProperties_Power">
        <compClass>DMSE.CompPowerPlantPhotovoltaic</compClass>
        <basePowerConsumption>-2500</basePowerConsumption>
        <transmitsPower>true</transmitsPower>
      </li>
      <li Class="CompProperties_Stunnable">
        <useLargeEMPEffecter>true</useLargeEMPEffecter>
        <empChancePerTick>0.03</empChancePerTick>
        <affectedDamageDefs>
          <li>EMP</li>
        </affectedDamageDefs>
      </li>
    </comps>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <designationCategory>Power</designationCategory>
    <uiOrder>2100</uiOrder>
    <constructEffect>ConstructMetal</constructEffect>
    <researchPrerequisites>
      <li>DMSE_OrbitalDynamics</li>
      <li>SolarPanels</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
  </ThingDef>
</Defs>