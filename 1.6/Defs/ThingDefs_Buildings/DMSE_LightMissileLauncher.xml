<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <!-- ==================== 輕型導彈 離場 skyfaller ==================== -->
  <ThingDef ParentName="SkyfallerBase">
    <defName>DMSE_SkyFaller_LightMissile</defName>
    <label>light missile (leaving)</label>
    <thingClass>DMSE.ScorerProjectile</thingClass>
    <size>(1,1)</size>
    <graphicData>
      <texPath>Things/Missile/Grison/skyFaller</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>2.5</drawSize>
    </graphicData>
    <skyfaller>
      <movementType>Accelerate</movementType>
      <reversed>true</reversed>
      <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
      <shadowSize>(1.5, 1.5)</shadowSize>
      <ticksToDiscardInReverse>300</ticksToDiscardInReverse>
      <ticksToImpactRange>0</ticksToImpactRange>
      <anticipationSound>DropPod_Leaving</anticipationSound>
      <anticipationSoundTicks>-1</anticipationSoundTicks>
      <speedCurve>
        <points>
          <li>(0,0.3)</li>
          <li>(0.2,0.2)</li>
          <li>(0.5,0.5)</li>
          <li>(1,1)</li>
        </points>
      </speedCurve>
      <rotationCurve>
        <points>
          <li>(0,-10)</li>
          <li>(0.30,-25)</li>
          <li>(0.6,-5)</li>
          <li>(1,0)</li>
        </points>
      </rotationCurve>
      <zPositionCurve>
        <points>
          <li>(0,0)</li>
          <li>(0.05,2)</li>
          <li>(0.3,1)</li>
          <li>(1,10)</li>
        </points>
      </zPositionCurve>
    </skyfaller>
    <comps>
      <li Class="DMSE.CompProperties_EffecterHotLaunch">
        <launchBlastScale>0.85</launchBlastScale>
        <ignitionSound>DMSE_Missile_Flight</ignitionSound>
        <ExhaustFleck>DMS_Fleck_RocketFlame</ExhaustFleck>
        <ExhaustCurve>
          <points>
            <li>(0,2)</li>
            <li>(0.1,6)</li>
            <li>(0.5,4)</li>
            <li>(0.9,2)</li>
          </points>
        </ExhaustCurve>
        <SmokeFleck>Smoke</SmokeFleck>
        <SmokeCurve>
          <points>
            <li>(0,4)</li>
            <li>(0.5,3)</li>
            <li>(1,1)</li>
          </points>
        </SmokeCurve>
        <launchEffectTrigger>DMS_LaunchDust_Recoilless</launchEffectTrigger>
      </li>
    </comps>
  </ThingDef>

  <!-- ==================== 輕型導彈 落點 incoming skyfaller ==================== -->
  <ThingDef ParentName="SkyfallerBase">
    <defName>DMSE_Incoming_LightMissile</defName>
    <label>light missile (incoming)</label>
    <thingClass>DMSE.MissileIncoming</thingClass>
    <graphicData>
      <texPath>Things/Missile/Grison/skyFaller</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>2.5</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <skyfaller>
      <shadowSize>(2, 2)</shadowSize>
      <rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection>
      <speed>1</speed>
    </skyfaller>
    <!-- BVR 特性：輕型導彈比巡航快，但比彈道慢；隱身適中。 -->
    <modExtensions>
      <li Class="DMSE.BVRTargetProps">
        <distanceLevel>1.2</distanceLevel>
        <stealthLevel>0.8</stealthLevel>
        <speed>22</speed>
      </li>
    </modExtensions>
  </ThingDef>

  <!-- ==================== 輕型導彈 世界旅行物件 ==================== -->
  <WorldObjectDef>
    <defName>DMSE_WorldObject_LightMissile</defName>
    <label>light missile</label>
    <description>A light missile in flight.</description>
    <worldObjectClass>DMSE.ScorerProjectile_WorldObject</worldObjectClass>
    <texture>UI/DMSE/TravelingMissile</texture>
    <rotateGraphicWhenTraveling>true</rotateGraphicWhenTraveling>
    <useDynamicDrawer>true</useDynamicDrawer>
    <expandingIcon>true</expandingIcon>
    <expandingIconTexture>UI/DMSE/TravelingMissile_Expanding</expandingIconTexture>
    <expandingIconPriority>100</expandingIconPriority>
    <expandMore>true</expandMore>
    <allowCaravanIncidentsWhichGenerateMap>true</allowCaravanIncidentsWhichGenerateMap>
    <fullyExpandedInSpace>true</fullyExpandedInSpace>
    <validLaunchTarget>false</validLaunchTarget>
  </WorldObjectDef>

  <!-- ==================== 輕型導彈 傾斜發射軌（1x3）====================
       參考 DMSE_Building_LoiteringLauncher 結構，提升成本以反映更高技術層次。
       容量 1 枚，需 DMSE_Ballistics 解鎖。 -->
  <ThingDef ParentName="DMSE_TiltLauncherBase">
    <defName>DMSE_Building_LightMissileLauncher</defName>
    <label>light missile rail</label>
    <description>A tilt-launch rail for a single light missile. Faster and more capable than a loitering munition rail, supporting customisable warhead, guidance, and payload configurations.</description>
    <thingClass>DMSE.Building_MissileRack</thingClass>
    <graphicData>
      <texPath>Things/Building/MissileLauncher/building</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2,4)</drawSize>
      <drawOffset>(0,0.00875,0)</drawOffset>
      <drawOffsetEast>(0,0.00875,0.35)</drawOffsetEast>
      <drawOffsetWest>(0,0.00875,0.35)</drawOffsetWest>
    </graphicData>
    <size>(1,3)</size>
    <pathCost>80</pathCost>
    <fillPercent>0.55</fillPercent>
    <staticSunShadowHeight>0.1</staticSunShadowHeight>
    <constructEffect>ConstructMetal</constructEffect>
    <statBases>
      <MaxHitPoints>350</MaxHitPoints>
      <WorkToBuild>7000</WorkToBuild>
      <Flammability>0.05</Flammability>
    </statBases>
    <costList>
      <Steel>150</Steel>
      <ComponentIndustrial>6</ComponentIndustrial>
    </costList>
    <building>
      <maxItemsInCell>1</maxItemsInCell>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <fixedStorageSettings>
        <filter>
          <thingDefs>
            <li>DMSE_LightMissile</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <thingDefs>
            <li>DMSE_LightMissile</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
    </building>
    <modExtensions>
      <li Class="DMSE.MissileLauncherExtension">
        <sizeClass>Light</sizeClass>
        <launchMode>Tilt</launchMode>
        <capacity>1</capacity>
      </li>
    </modExtensions>
    <comps>
      <li Class="DMSE.CompProperties_MissileRackRenderer">
        <maxStored>1</maxStored>
        <useNativeDrawSize>true</useNativeDrawSize>
        <slotOffsets>
          <li>(0, 0, 0)</li>
        </slotOffsets>
      </li>
      <li Class="DMSE.CompProperties_MissileRailLauncher">
        <skyfaller>DMSE_SkyFaller_LightMissile</skyfaller>
        <skyfallerIncoming>DMSE_Incoming_LightMissile</skyfallerIncoming>
        <worldObjectDef>DMSE_WorldObject_LightMissile</worldObjectDef>
        <missileBody>DMSE_MissileBody_Light</missileBody>
        <launchCooldownTicks>450</launchCooldownTicks>
        <launchForwardCells>2</launchForwardCells>
      </li>
    </comps>
    <inspectorTabs>
      <li>RimWorld.ITab_Storage</li>
      <li>DMSE.ITab_MissileInventory</li>
      <li>DMSE.ITab_MissileAssembly</li>
    </inspectorTabs>
    <researchPrerequisites>
      <li>DMSE_Ballistics</li>
    </researchPrerequisites>
  </ThingDef>

  <!-- ==================== 輕型導彈 垂直發射單元（1x1）====================
       單格 VLS 單元，適合密集部署或空間受限場合。
       不可旋轉（垂直朝向），禁止建於重力船 substructure。 -->
  <ThingDef ParentName="DMSE_VerticalLauncherBase">
    <defName>DMSE_Building_LightMissileVLS</defName>
    <label>light missile VLS cell</label>
    <description>A single-cell vertical launch system for light missiles. Compact footprint allows dense battery deployment. Cannot be installed on gravship decks.</description>
    <thingClass>DMSE.Building_MissileRack</thingClass>
    <graphicData>
      <!-- 暫借 1x1 貼圖；建議後期替換為獨立 VLS 頂蓋貼圖。 -->
      <texPath>Things/Building/MissileLauncher/building</texPath>
      <graphicClass>Graphic_Multi</graphicClass>
      <drawSize>(2,2)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <pathCost>60</pathCost>
    <fillPercent>0.8</fillPercent>
    <constructEffect>ConstructMetal</constructEffect>
    <statBases>
      <MaxHitPoints>200</MaxHitPoints>
      <WorkToBuild>4000</WorkToBuild>
      <Flammability>0.05</Flammability>
    </statBases>
    <costList>
      <Steel>80</Steel>
      <ComponentIndustrial>3</ComponentIndustrial>
    </costList>
    <building>
      <maxItemsInCell>1</maxItemsInCell>
      <ignoreStoredThingsBeauty>true</ignoreStoredThingsBeauty>
      <fixedStorageSettings>
        <filter>
          <thingDefs>
            <li>DMSE_LightMissile</li>
          </thingDefs>
        </filter>
      </fixedStorageSettings>
      <defaultStorageSettings>
        <priority>Important</priority>
        <filter>
          <thingDefs>
            <li>DMSE_LightMissile</li>
          </thingDefs>
        </filter>
      </defaultStorageSettings>
    </building>
    <modExtensions>
      <li Class="DMSE.MissileLauncherExtension">
        <sizeClass>Light</sizeClass>
        <launchMode>Vertical</launchMode>
        <capacity>1</capacity>
      </li>
    </modExtensions>
    <comps>
      <li Class="DMSE.CompProperties_MissileRackRenderer">
        <maxStored>1</maxStored>
        <useNativeDrawSize>true</useNativeDrawSize>
        <slotOffsets>
          <li>(0, 0, 0)</li>
        </slotOffsets>
      </li>
      <li Class="DMSE.CompProperties_MissileRailLauncher">
        <skyfaller>DMSE_SkyFaller_LightMissile</skyfaller>
        <skyfallerIncoming>DMSE_Incoming_LightMissile</skyfallerIncoming>
        <worldObjectDef>DMSE_WorldObject_LightMissile</worldObjectDef>
        <missileBody>DMSE_MissileBody_Light</missileBody>
        <launchCooldownTicks>450</launchCooldownTicks>
        <launchForwardCells>1</launchForwardCells>
      </li>
    </comps>
    <inspectorTabs>
      <li>RimWorld.ITab_Storage</li>
      <li>DMSE.ITab_MissileInventory</li>
      <li>DMSE.ITab_MissileAssembly</li>
    </inspectorTabs>
    <researchPrerequisites>
      <li>DMSE_Ballistics</li>
    </researchPrerequisites>
  </ThingDef>

</Defs>
