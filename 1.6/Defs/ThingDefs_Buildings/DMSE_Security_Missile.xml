<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <ThingDef ParentName="BuildingBase">
        <defName>DMSE_Building_Scorer</defName>
        <label>Scorer MLS</label>
        <description>The S1120 "Scorer" is a cruise missile launch system. It is a highly versatile anti-ship missile launcher used on cruisers and armed landing ships of the Colonial Fleet.</description>
        <category>Building</category>
        <graphicData>
            <texPath>Things/Building/MissileLauncher/building</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,6)</drawSize>
            <drawOffset>(0,0.00875,0)</drawOffset>
            <drawOffsetEast>(0,0.00875,0.35)</drawOffsetEast>
            <drawOffsetWest>(0,0.00875,0.35)</drawOffsetWest>
        </graphicData>
        <rotatable>true</rotatable>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>100</pathCost>
        <constructEffect>ConstructMetal</constructEffect>
        <tickerType>Normal</tickerType>
        <drawerType>RealtimeOnly</drawerType>
        <fillPercent>0.9</fillPercent>
        <designationCategory>DMS_Category</designationCategory>
        <size>(1,5)</size>
        <staticSunShadowHeight>0.1</staticSunShadowHeight>
        <statBases>
            <MaxHitPoints>500</MaxHitPoints>
            <WorkToBuild>10000</WorkToBuild>
            <Flammability>0.05</Flammability>
        </statBases>
        <selectable>true</selectable>
        <costList>
            <Steel>250</Steel>
            <ComponentStamped>10</ComponentStamped>
            <ComponentSpacer>1</ComponentSpacer>
        </costList>
        <building>
            <destroySound>BuildingDestroyed_Metal_Small</destroySound>
        </building>
        <soundImpactDefault>BulletImpact_Ground</soundImpactDefault>
        <leaveResourcesWhenKilled>false</leaveResourcesWhenKilled>
        <drawPlaceWorkersWhileSelected>true</drawPlaceWorkersWhileSelected>
        <!-- 四階分類：中型階、傾斜發射、彈容 1。作為平台分類架構的具體範本。 -->
        <modExtensions>
            <li Class="DMSE.MissileLauncherExtension">
                <sizeClass>Medium</sizeClass>
                <launchMode>Tilt</launchMode>
                <capacity>1</capacity>
            </li>
        </modExtensions>
        <comps>
            <li Class="DMSE.CompPropertiesScorer">
                <skyfaller>DMSE_SkyFaller_CruiseMissile</skyfaller>
                <skyfallerIncoming>DMSE_Incoming_CruiseMissile</skyfallerIncoming>
                <worldObjectDef>DMSE_WorldObject_CruiseMissile</worldObjectDef>
            </li>
            <li Class="CompProperties_Refuelable">
                <fuelGizmoLabel>Loaded missile</fuelGizmoLabel>
                <fuelFilter>
                    <thingDefs>
                        <li>DMSE_CruiseMissile</li>
                    </thingDefs>
                </fuelFilter>
                <fuelIsMortarBarrel>false</fuelIsMortarBarrel>
                <fuelCapacity>1</fuelCapacity>
                <fuelMultiplier>1</fuelMultiplier>
                <initialFuelPercent>0</initialFuelPercent>
                <showFuelGizmo>true</showFuelGizmo>
                <minimumFueledThreshold>1</minimumFueledThreshold>
                <consumeFuelOnlyWhenUsed>true</consumeFuelOnlyWhenUsed>
                <initialAllowAutoRefuel>true</initialAllowAutoRefuel>
                <autoRefuelPercent>0</autoRefuelPercent>
                <fuelIconPath>UI/DMSE/TravelingMissile</fuelIconPath>
            </li>
            <!-- 接收已裝填導彈的裝配設定（由 Patch_Refuel_CarryConfig 於裝填時複製）。 -->
            <li Class="DMSE.CompProperties_MissileConfig">
                <defaultBody>DMSE_MissileBody_Cruise</defaultBody>
            </li>
        </comps>
        <researchPrerequisites>
            <li>DMSE_OrbitalDynamics</li>
        </researchPrerequisites>
    </ThingDef>

    <ThingDef ParentName="SkyfallerBase">
        <defName>DMSE_SkyFaller_CruiseMissile</defName>
        <label>cruise missile (leaving)</label>
        <size>(1,1)</size>
        <graphicData>
            <texPath>Things/Missile/Moskit/skyFaller_moskit</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>4</drawSize>
        </graphicData>
        <thingClass>DMSE.ScorerProjectile</thingClass>
        <skyfaller>
            <movementType>Accelerate</movementType>
            <reversed>true</reversed>
            <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
            <shadowSize>(2, 2)</shadowSize>
            <ticksToDiscardInReverse>300</ticksToDiscardInReverse>
            <ticksToImpactRange>0</ticksToImpactRange>
            <anticipationSound>DropPod_Leaving</anticipationSound>
            <anticipationSoundTicks>-1</anticipationSoundTicks>
            <speedCurve>
                <points>
                    <li>(0,0.3)</li>
                    <li>(0.2,0.2)</li>
                    <li>(0.5,0.5)</li>
                    <li>(1,1)</li>
                </points>
            </speedCurve>
            <rotationCurve>
                <points>
                    <li>(0,-10)</li>
                    <li>(0.30,-25)</li>
                    <li>(0.6,-5)</li>
                    <li>(1,0)</li>
                </points>
            </rotationCurve>
            <zPositionCurve>
                <points>
                    <li>(0,0)</li>
                    <li>(0.05,2)</li>
                    <li>(0.3,1)</li>
                    <li>(1,10)</li>
                </points>
            </zPositionCurve>
        </skyfaller>
        <comps>
            <li Class="DMSE.CompProperties_EffecterColdLaunch">
                <delayTicks>40</delayTicks>
                <ignitionSound>DMSE_Missile_Flight</ignitionSound>
                <ExhaustFleck>DMS_Fleck_RocketFlame</ExhaustFleck>
                <ExhaustCurve>
                    <points>
                        <li>(0,2)</li>
                        <li>(0.1,8)</li>
                        <li>(0.5,4)</li>
                        <li>(0.9,2)</li>
                    </points>
                </ExhaustCurve>
                <SmokeFleck>Smoke</SmokeFleck>
                <SmokeCurve>
                    <points>
                        <li>(0,12)</li>
                        <li>(0.5,9)</li>
                        <li>(1,2)</li>
                    </points>
                </SmokeCurve>
                <launchEffectTrigger>DMS_LaunchDust_Recoilless</launchEffectTrigger>
            </li>
        </comps>
    </ThingDef>

    <WorldObjectDef>
        <defName>DMSE_WorldObject_CruiseMissile</defName>
        <label>cruise missile</label>
        <description>cruise missile in flight.</description>
        <worldObjectClass>DMSE.ScorerProjectile_WorldObject</worldObjectClass>
        <texture>UI/DMSE/TravelingMissile</texture>
        <rotateGraphicWhenTraveling>true</rotateGraphicWhenTraveling>
        <useDynamicDrawer>true</useDynamicDrawer>
        <expandingIcon>true</expandingIcon>
        <expandingIconTexture>UI/DMSE/TravelingMissile_Expanding</expandingIconTexture>
        <expandingIconPriority>100</expandingIconPriority>
        <expandMore>true</expandMore>
        <allowCaravanIncidentsWhichGenerateMap>true</allowCaravanIncidentsWhichGenerateMap>
        <fullyExpandedInSpace>true</fullyExpandedInSpace>
        <validLaunchTarget>false</validLaunchTarget>
    </WorldObjectDef>

    <!-- 通用來襲導彈（任何陣營皆可發射，抵達後自動落點生成 MissileIncoming） -->
    <WorldObjectDef>
        <defName>DMSE_WorldObject_IncomingMissile</defName>
        <label>incoming missile</label>
        <description>A missile inbound to a target.</description>
        <worldObjectClass>DMSE.WorldObject_IncomingMissile</worldObjectClass>
        <texture>UI/DMSE/TravelingMissile</texture>
        <rotateGraphicWhenTraveling>true</rotateGraphicWhenTraveling>
        <useDynamicDrawer>true</useDynamicDrawer>
        <expandingIcon>true</expandingIcon>
        <expandingIconTexture>UI/DMSE/TravelingMissile_Expanding</expandingIconTexture>
        <expandingIconPriority>100</expandingIconPriority>
        <expandMore>true</expandMore>
        <fullyExpandedInSpace>true</fullyExpandedInSpace>
        <validLaunchTarget>false</validLaunchTarget>
    </WorldObjectDef>

    <ThingDef ParentName="SkyfallerBase">
        <defName>DMSE_Incoming_CruiseMissile</defName>
        <label>cruise missile (incoming)</label>
        <thingClass>DMSE.MissileIncoming</thingClass>
        <graphicData>
            <texPath>Things/Missile/Moskit/skyFaller_moskit_incoming</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>4</drawSize>
        </graphicData>
        <size>(1,1)</size>
        <!-- 爆炸效果改由導彈裝配設定（MissileConfig）於落點動態套用，故此處不設固定 explosionRadius/explosionDamage。 -->
        <skyfaller>
            <shadowSize>(3, 3)</shadowSize>
            <rotateGraphicTowardsDirection>true</rotateGraphicTowardsDirection>
            <speed>1</speed>
        </skyfaller>
        <!-- BVR 攔截特性：巡航導彈有完整世界航跡，可較早偵測（窗口需大於末端窗口，
             中過程 SAM 與末端 CIWS 才會依序作用）；仍需一定反隱身才能完整偵測。 -->
        <modExtensions>
            <li Class="DMSE.BVRTargetProps">
                <distanceLevel>1.5</distanceLevel>
                <stealthLevel>1</stealthLevel>
                <speed>30</speed>
            </li>
        </modExtensions>
    </ThingDef>

    <!-- ==================== 中程防空攔截彈（skyfaller，由 CompMissileLauncher 發射） ==================== -->
    <ThingDef ParentName="SkyfallerBase">
        <defName>DMSE_SkyFaller_Interceptor</defName>
        <label>interceptor missile</label>
        <thingClass>DMSE.InterceptProjectile</thingClass>
        <size>(1,1)</size>
        <graphicData>
            <texPath>Things/Missile/Moskit/skyFaller_moskit</texPath>
            <graphicClass>Graphic_Single</graphicClass>
            <drawSize>2.5</drawSize>
        </graphicData>
        <!-- 與巡航導彈相同的發射軌跡 -->
        <skyfaller>
            <movementType>Accelerate</movementType>
            <reversed>true</reversed>
            <shadow>Things/Skyfaller/SkyfallerShadowDropPod</shadow>
            <shadowSize>(2, 2)</shadowSize>
            <ticksToDiscardInReverse>300</ticksToDiscardInReverse>
            <ticksToImpactRange>0</ticksToImpactRange>
            <anticipationSound>DropPod_Leaving</anticipationSound>
            <anticipationSoundTicks>-1</anticipationSoundTicks>
            <speedCurve>
                <points>
                    <li>(0,0.3)</li>
                    <li>(0.2,0.2)</li>
                    <li>(0.5,0.5)</li>
                    <li>(1,1)</li>
                </points>
            </speedCurve>
            <rotationCurve>
                <points>
                    <li>(0,-10)</li>
                    <li>(0.30,-25)</li>
                    <li>(0.6,-5)</li>
                    <li>(1,0)</li>
                </points>
            </rotationCurve>
            <zPositionCurve>
                <points>
                    <li>(0,0)</li>
                    <li>(0.05,2)</li>
                    <li>(0.3,1)</li>
                    <li>(1,10)</li>
                </points>
            </zPositionCurve>
        </skyfaller>
        <!-- SAM 熱發射特效：尾管立即點火、強烈初始噴焰（排氣火焰、煙霧、點火音效） -->
        <comps>
            <li Class="DMSE.CompProperties_EffecterHotLaunch">
                <launchBlastScale>1</launchBlastScale>
                <ignitionSound>DMSE_Missile_Flight</ignitionSound>
                <ExhaustFleck>DMS_Fleck_RocketFlame</ExhaustFleck>
                <ExhaustCurve>
                    <points>
                        <li>(0,2)</li>
                        <li>(0.1,6)</li>
                        <li>(0.5,4)</li>
                        <li>(0.9,2)</li>
                    </points>
                </ExhaustCurve>
                <SmokeFleck>Smoke</SmokeFleck>
                <SmokeCurve>
                    <points>
                        <li>(0,3)</li>
                        <li>(0.5,2)</li>
                        <li>(1,1)</li>
                    </points>
                </SmokeCurve>
                <launchEffectTrigger>DMS_LaunchDust_Recoilless</launchEffectTrigger>
            </li>
        </comps>
    </ThingDef>

    <!-- ==================== 防空導彈發射裝置 ====================
         功能由 ThingComp 提供；可獨立成棟，也可掛在其他建築上組合複合功能。
         此處未掛 CompRefuelable，攔截彈無限但受 reloadCooldownTicks 節流；
         若要限制彈藥，可加 CompProperties_Refuelable 並設定對應彈藥物品。 -->
    <ThingDef ParentName="BuildingBase">
        <defName>DMSE_Building_SAMLauncher</defName>
        <label>SAM launcher</label>
        <description>A surface-to-air missile launcher. Guided by a fire-control radar, it engages incoming hostile drops during the midcourse phase of the beyond-visual-range combat system.</description>
        <category>Building</category>
        <graphicData>
            <texPath>Things/Building/MissileLauncher/building</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(2,6)</drawSize>
            <drawOffset>(0,0.00875,0)</drawOffset>
            <drawOffsetEast>(0,0.00875,0.35)</drawOffsetEast>
            <drawOffsetWest>(0,0.00875,0.35)</drawOffsetWest>
        </graphicData>
        <rotatable>true</rotatable>
        <altitudeLayer>Building</altitudeLayer>
        <passability>PassThroughOnly</passability>
        <pathCost>100</pathCost>
        <fillPercent>0.9</fillPercent>
        <tickerType>Normal</tickerType>
        <drawerType>RealtimeOnly</drawerType>
        <designationCategory>DMS_Category</designationCategory>
        <size>(1,5)</size>
        <staticSunShadowHeight>0.1</staticSunShadowHeight>
        <statBases>
            <MaxHitPoints>500</MaxHitPoints>
            <WorkToBuild>9000</WorkToBuild>
            <Flammability>0.05</Flammability>
        </statBases>
        <costList>
            <Steel>200</Steel>
            <ComponentStamped>8</ComponentStamped>
            <ComponentSpacer>2</ComponentSpacer>
        </costList>
        <comps>
            <li Class="CompProperties_Power">
                <compClass>CompPowerTrader</compClass>
                <basePowerConsumption>400</basePowerConsumption>
            </li>
            <li Class="CompProperties_Flickable" />
            <li Class="CompProperties_Breakdownable" />
            <li Class="DMSE.CompProperties_MissileLauncher">
                <interceptorSkyfaller>DMSE_SkyFaller_Interceptor</interceptorSkyfaller>
                <reloadCooldownTicks>240</reloadCooldownTicks>
                <interceptorTravelTicks>300</interceptorTravelTicks>
            </li>
        </comps>
        <researchPrerequisites>
            <li>DMSE_OrbitalDynamics</li>
        </researchPrerequisites>
    </ThingDef>
</Defs>