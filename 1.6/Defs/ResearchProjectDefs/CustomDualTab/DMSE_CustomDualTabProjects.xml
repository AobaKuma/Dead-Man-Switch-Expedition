<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- Basic Knowledge Category Project Example -->
   
  <ResearchProjectDef Name="DMSE_BaseOccultTech" Abstract="True">
    <tab>DMSE_ExpeditionalKnowledge</tab>
    <knowledgeCategory>DMSE_Restricted</knowledgeCategory>
    <knowledgeCost>750</knowledgeCost>
  </ResearchProjectDef>

  <ResearchProjectDef ParentName="DMSE_BaseOccultTech">
    <defName>DMSE_ExpKnowledge_BasicFoundation</defName>
    <label>expeditional basic foundation</label>
    <description>Establish fundamental understanding of expeditional technology and principles.</description>
    <researchViewX>1</researchViewX>
    <researchViewY>1</researchViewY>
    <knowledgeCost>500</knowledgeCost>
  </ResearchProjectDef>

  <!-- Advanced Knowledge Category Project Example -->
  <ResearchProjectDef>
    <defName>DMSE_ExpKnowledge_AdvancedMastery</defName>
    <label>expeditional advanced mastery</label>
    <description>Master advanced expeditional technology and unlock powerful applications.</description>
    <!-- <baseCost>2000</baseCost> -->
    <prerequisites>
      <li>DMSE_ExpKnowledge_BasicFoundation</li>
    </prerequisites>
    <tab>DMSE_ExpeditionalKnowledge</tab>
    <researchViewX>3</researchViewX>
    <researchViewY>1</researchViewY>
    <knowledgeCategory>DMSE_Sealed</knowledgeCategory>
    <knowledgeCost>1000</knowledgeCost>
  </ResearchProjectDef>

  <!-- Additional Basic Tier Project -->
  <ResearchProjectDef>
    <defName>DMSE_ExpKnowledge_BasicSecondary</defName>
    <label>expeditional basic secondary</label>
    <description>Secondary basic knowledge to support advanced research.</description>
    <!-- <baseCost>800</baseCost> -->
    <tab>DMSE_ExpeditionalKnowledge</tab>
    <researchViewX>4</researchViewX>
    <researchViewY>2</researchViewY>
    <prerequisites>
      <li>DMSE_ExpKnowledge_AdvancedMastery</li>
    </prerequisites>
    <knowledgeCategory>DMSE_Occulted</knowledgeCategory>
    <knowledgeCost>400</knowledgeCost>
  </ResearchProjectDef>

</Defs>
