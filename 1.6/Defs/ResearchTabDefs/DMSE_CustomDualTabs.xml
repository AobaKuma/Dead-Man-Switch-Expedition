<?xml version="1.0" encoding="utf-8"?>
<Defs>
  <!-- 自訂雙槽研究分頁示例 - Custom dual-slot research tab example -->
  <ResearchTabDef>
    <defName>DMSE_ExpeditionalKnowledge</defName>
    <label>Occultech</label>
    <generalTitle>Expeditional Knowledge</generalTitle>
    <generalDescription>Advanced technologies held by colonial fleets but not openly used or circulated. mostly prohibited from circulation due to their danger or the potential for irreversible and far-reaching impact on the local world.</generalDescription>
    <visibleByDefault>true</visibleByDefault>
    <modExtensions>
      <li Class="DMSE.ModExtension_UniqueResearchTab">
        <categories>
          <!-- Reference existing KnowledgeCategoryDef defNames here - these are example names -->
          <li>DMSE_Restricted</li>
          <li>DMSE_Sealed</li>
          <li>DMSE_Occulted</li>
        </categories>
      </li>
    </modExtensions>
  </ResearchTabDef>

  <KnowledgeCategoryDef>
    <defName>DMSE_Restricted</defName>
    <label>restricted</label>
    <color>(0.6, 0.6, 0.4, 1)</color>
    <texPath>UI/DMSE/ResearchCategory_Restricted</texPath>
  </KnowledgeCategoryDef>

  <KnowledgeCategoryDef>
    <defName>DMSE_Sealed</defName>
    <label>sealed</label>
    <color>(1, 0.5, 0.1, 1)</color>
    <texPath>UI/DMSE/ResearchCategory_Sealed</texPath>
    <overflowCategory>DMSE_Restricted</overflowCategory>
  </KnowledgeCategoryDef>

  <KnowledgeCategoryDef>
    <defName>DMSE_Occulted</defName>
    <label>occulted</label>
    <color>(1, 0, 0, 1)</color>
    <texPath>UI/DMSE/ResearchCategory_Occulted</texPath>
    <overflowCategory>DMSE_Sealed</overflowCategory>
  </KnowledgeCategoryDef>
</Defs>