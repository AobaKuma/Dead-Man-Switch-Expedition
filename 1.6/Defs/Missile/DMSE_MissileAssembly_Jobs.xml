<?xml version="1.0" encoding="utf-8"?>
<Defs>

  <JobDef>
    <defName>DMSE_DeliverMissileResource</defName>
    <driverClass>DMSE.JobDriver_DeliverMissileResource</driverClass>
    <reportString>delivering parts to TargetA.</reportString>
  </JobDef>

  <JobDef>
    <defName>DMSE_AssembleMissile</defName>
    <driverClass>DMSE.JobDriver_AssembleMissile</driverClass>
    <reportString>assembling TargetA.</reportString>
  </JobDef>

  <WorkGiverDef>
    <defName>DMSE_AssembleMissile</defName>
    <label>assemble missiles</label>
    <giverClass>DMSE.WorkGiver_AssembleMissile</giverClass>
    <workType>Crafting</workType>
    <verb>assemble</verb>
    <gerund>assembling</gerund>
    <scanThings>true</scanThings>
    <scanCells>false</scanCells>
    <priorityInType>50</priorityInType>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

  <!-- 從導彈儲存架取出導彈裝填至發射平台（儲存架內的 unspawned 導彈無法被標準搬運系統處理） -->
  <JobDef>
    <defName>DMSE_LoadMissileLauncher</defName>
    <driverClass>DMSE.JobDriver_LoadMissileLauncher</driverClass>
    <reportString>loading missile into TargetA.</reportString>
  </JobDef>

  <WorkGiverDef>
    <defName>DMSE_LoadMissileLauncher</defName>
    <label>load missile launchers</label>
    <giverClass>DMSE.WorkGiver_LoadMissileLauncher</giverClass>
    <workType>Hauling</workType>
    <verb>load</verb>
    <gerund>loading</gerund>
    <scanThings>true</scanThings>
    <scanCells>false</scanCells>
    <priorityInType>85</priorityInType>
    <requiredCapacities>
      <li>Manipulation</li>
    </requiredCapacities>
  </WorkGiverDef>

</Defs>
