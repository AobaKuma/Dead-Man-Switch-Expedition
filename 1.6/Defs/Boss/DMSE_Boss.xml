<Defs>

    <ThingDef ParentName="DMS_BossCallerBase">
        <defName>DMSE_DecoyRadio</defName>
        <label>Decoy radio</label>
        <description>A high-powered radio, used fake radio signals to lure away the automated defense systems that still exist on the planet. Once activated, it puts out a powerful wave radiation signal which will attract ultra heavy automatroid to attack along with its escorts. If you can defeat it, you can collect the advanced technology from its corpse. The signal pulse burns out the transmitter, so this building can only be used once.</description>
        <descriptionHyperlinks>
            <ThingDef>DMSE_Mech_ClusterWeaver</ThingDef>
            <ThingDef>ComponentControlChip</ThingDef>
        </descriptionHyperlinks>
        <graphicData>
            <texPath>Things/Building/DecoyRadio</texPath>
            <graphicClass>Graphic_Multi</graphicClass>
            <drawSize>(3,3)</drawSize>
            <shadowData>
                <volume>(1.7, 0.75, 0.8)</volume>
                <offset>(0.15, 0, 0)</offset>
            </shadowData>
        </graphicData>
        <size>(3,3)</size>
        <costList>
            <Steel>50</Steel>
            <ComponentIndustrial>3</ComponentIndustrial>
            <ComponentSpacer>1</ComponentSpacer>
        </costList>
        <researchPrerequisites>
            <li>DMSE_OrbitalDynamics</li>
        </researchPrerequisites>
        <comps>
            <li Class="CompProperties_Usable">
                <useJob>TriggerObject</useJob>
                <useLabel>Attract cluster weaver threat</useLabel>
                <useDuration>900</useDuration>
                <floatMenuFactionIcon>DMS_Legacy</floatMenuFactionIcon>
            </li>
            <li Class="DMS.CompPropertiesUseable_SummonRaid">
                <bossgroupDef>DMSE_ClusterWeaver</bossgroupDef>
                <effecterDef>BurnoutMechlinkBoosterUsed</effecterDef>
            </li>
            <li Class="CompProperties_UseEffectDestroySelf">
                <delayTicks>120</delayTicks>
                <spawnKilledLeavings>true</spawnKilledLeavings>
                <effecterDef>MechbandBuildingDestroyed</effecterDef>
            </li>
        </comps>
    </ThingDef>

    <BossDef>
        <defName>DMS_Boss_ClusterWeaver</defName>
        <kindDef>DMSE_Mech_ClusterWeaver</kindDef>
        <appearAfterTicks>7200000</appearAfterTicks><!-- 2 years -->
    </BossDef>

    <BossgroupDef ParentName="BaseBossgroupNonMechanitor">
        <defName>DMSE_ClusterWeaver</defName>
        <boss>DMS_Boss_ClusterWeaver</boss>
        <leaderDescription>The {LEADERKIND_label} is a nightmare since ww3, it's not a weapon suitable in a total war but a perfect machine for counterinsurgency, be aware of it can deploy suicide drone swarm to overrun your defense.</leaderDescription>
        <waves>
            <li> <!-- 0 -->
                <bossCount>1</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>2</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>3</DMS_Mech_Soldat>
                </escorts>
            </li>
            <li> <!-- 1 -->
                <bossCount>1</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>5</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>5</DMS_Mech_Soldat>
                </escorts>
            </li>
            <li> <!-- 2 - Repeat starts here -->
                <bossCount>2</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>4</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>10</DMS_Mech_Soldat>
                    <DMS_Mech_Falcon>7</DMS_Mech_Falcon>
                </escorts>
            </li>
            <li> <!-- 3 -->
                <bossCount>3</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>6</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>10</DMS_Mech_Soldat>
                    <DMS_Mech_Ronin>10</DMS_Mech_Ronin>
                </escorts>
                <bossApparel>
                    <li>
                        <thing>Apparel_HeavyShield</thing>
                    </li>
                </bossApparel>
            </li>
            <li> <!-- 4 -->
                <bossCount>4</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>8</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>10</DMS_Mech_Soldat>
                    <DMS_Mech_Ronin>5</DMS_Mech_Ronin>
                </escorts>
                <bossApparel>
                    <li>
                        <thing>Apparel_HeavyShield</thing>
                    </li>
                </bossApparel>
            </li>
            <li> <!-- 5 -->
                <bossCount>5</bossCount>
                <escorts>
                    <DMS_Mech_Falcon>8</DMS_Mech_Falcon>
                    <DMS_Mech_Soldat>15</DMS_Mech_Soldat>
                    <DMS_Mech_Ronin>8</DMS_Mech_Ronin>
                    <DMS_Mech_Sniper>2</DMS_Mech_Sniper>
                </escorts>
                <bossApparel>
                    <li>
                        <thing>Apparel_HeavyShield</thing>
                    </li>
                </bossApparel>
            </li>
        </waves>
        <rewardDef>ComponentControlChip</rewardDef>
    </BossgroupDef>
</Defs>