<?xml version="1.0" encoding="utf-8"?>
<Defs>
    <WorldGenStepDef>
        <defName>DMSE_ImpactCraterBiomeOverlay</defName>
        <order>210</order>
        <worldGenStep Class="DMSE.WorldGenStep_ImpactCrater" />
    </WorldGenStepDef>

    <GenStepDef>
        <defName>DMSE_Crater_DepositsRadial</defName>
        <order>238</order>
        <genStep Class="DMSE.GenStep_ImpactCraterDeposits">
            <coreObsidianChance>0.05</coreObsidianChance>
            <coreComponentsChance>0.18</coreComponentsChance>
            <coreSteelChance>0.12</coreSteelChance>
            <vacstoneScarChanceCore>0.30</vacstoneScarChanceCore>

            <rimObsidianChance>0.14</rimObsidianChance>
            <rimComponentsChance>0.10</rimComponentsChance>
            <rimSteelChance>0.22</rimSteelChance>
            <rimSlagChance>0.01</rimSlagChance>
            <vacstoneScarChanceRim>0.18</vacstoneScarChanceRim>

            <ejectaObsidianChance>0.03</ejectaObsidianChance>
            <ejectaComponentsChance>0.03</ejectaComponentsChance>
            <ejectaSteelChance>0.08</ejectaSteelChance>
            <ejectaSlagChance>0.01</ejectaSlagChance>
            <vacstoneScarChanceEjecta>0.05</vacstoneScarChanceEjecta>
        </genStep>
    </GenStepDef>

    <BiomeDef>
        <defName>DMSE_ImpactCraterBiome</defName>
        <label>impact crater wasteland</label>
        <description>Ancient impact basin filled with compacted machinery, steel remnants, and vacstone strata.</description>

        <!-- 用現成 worker，避免額外 worker class -->
        <workerClass>BiomeWorker_LavaField</workerClass>

        <canAutoChoose>false</canAutoChoose>
        <generatesNaturally>false</generatesNaturally>
        <allowRoads>false</allowRoads>
        <allowRivers>false</allowRivers>

        <animalDensity>0.05</animalDensity>
        <plantDensity>0.05</plantDensity>
        <forageability>0.05</forageability>
        <wildPlantRegrowDays>45</wildPlantRegrowDays>
        <movementDifficulty>1.2</movementDifficulty>
        <hasVirtualPlants>false</hasVirtualPlants>

        <!-- 避免 StartInitialWeather 在空天氣清單上隨機導致崩潰 -->
        <baseWeatherCommonalities>
            <Clear>12</Clear>
            <Rain>1</Rain>
            <DryThunderstorm>1</DryThunderstorm>
        </baseWeatherCommonalities>

        <!-- 關鍵：強制岩石類型為 Vacstone -->
        <forceRockTypes>
            <li>Vacstone</li>
        </forceRockTypes>

        <terrainPatchMakers>
            <li>
                <perlinFrequency>0.035</perlinFrequency>
                <perlinLacunarity>1.5</perlinLacunarity>
                <perlinOctaves>6</perlinOctaves>
                <isPond>true</isPond>
                <thresholds>
                    <li>
                        <terrain>VolcanicRock</terrain>
                        <min>0.6</min>
                        <max>0.9</max>
                    </li>
                    <li>
                        <terrain>LavaDeep</terrain>
                        <min>0.9</min>
                        <max>999</max>
                    </li>
                </thresholds>
            </li>
        </terrainPatchMakers>
        <allowedPackAnimals>
            <li>Muffalo</li>
            <li>Dromedary</li>
            <li>Elephant</li>
            <li>Alpaca</li>
        </allowedPackAnimals>
        <soundsAmbient>
            <li>Ambient_NightInsects_Standard</li>
        </soundsAmbient>
        <diseaseMtbDays>65</diseaseMtbDays>
        <!-- 關鍵：附加資源生成 step -->
        <extraGenSteps>
            <li>DMSE_Crater_DepositsRadial</li>
        </extraGenSteps>

        <texture>World/Biomes/LavaFields</texture>
    </BiomeDef>
</Defs>